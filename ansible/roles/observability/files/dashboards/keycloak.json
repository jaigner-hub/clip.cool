          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_server_requests_seconds_sum{job=\"keycloak\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"keycloak\"}[5m]))",
          "refId": "A",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "showPoints": "never",
            "lineWidth": 2,
