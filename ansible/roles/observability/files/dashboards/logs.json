{
  "uid": "keygrip-logs",
  "title": "Keygrip — Logs",
  "tags": ["keygrip", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(container)",
        "query": { "label": "container", "stream": "", "type": 1, "refId": "LokiVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "search",
        "label": "Filter (regex)",
        "type": "textbox",
        "query": "",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log volume by container",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 70, "lineWidth": 0, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true, "placement": "right", "displayMode": "table", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum by (container) (count_over_time({container=~\"$container\"} |~ \"(?i)$search\" [$__auto]))", "legendFormat": "{{container}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error / warning rate by container",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 2, "stacking": { "mode": "normal" } }, "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true, "placement": "right", "displayMode": "table", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum by (container) (count_over_time({container=~\"$container\"} |~ \"(?i)(error|warn|fatal|exception|panic|traceback)\" [$__auto]))", "legendFormat": "{{container}}" }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 16 },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{container=~\"$container\"} |~ \"(?i)$search\"", "maxLines": 1000 }
      ]
    }
  ]
}
