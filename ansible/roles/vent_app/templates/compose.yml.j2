name: keygrip-vent

services:
  vent-server:
    image: {{ vent_server_image }}
    restart: unless-stopped
    env_file: .env
    extra_hosts:
      - "host.docker.internal:host-gateway"   # DB (HAProxy) + LiveKit API live on the host
    ports:
      - "127.0.0.1:8086:8080"   # loopback (debug); reached on the edge net as vent-server:8080
    networks: [edge]

  # The single chat.vent.dog origin (the tunnel ingress points at vent-web:80).
  vent-web:
    image: {{ vent_client_image }}
    restart: unless-stopped
    depends_on: [vent-server]
    volumes:
      - {{ vent_dir }}/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks: [edge]

networks:
  edge:
    name: keygrip-edge
    external: true
