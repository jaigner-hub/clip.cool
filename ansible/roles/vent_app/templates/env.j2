# vent-server runtime config — rendered 0600 from SOPS. Consumed by the container via env_file.
PORT=8080
BIND_ADDR=0.0.0.0

# Postgres (shared HA cluster) via HAProxy write port on the host.
DATABASE_URL=postgres://{{ vent_db_user }}:{{ vault_vent_db_password }}@{{ vent_db_host }}:{{ vent_db_port }}/{{ vent_db_name }}?sslmode=disable

# Dendrite (same edge network) + the shared-secret admin endpoint for user provisioning.
DENDRITE_URL=http://dendrite:8008
DENDRITE_REGISTRATION_SECRET={{ vault_dendrite_registration_shared_secret }}
MATRIX_SERVER_NAME={{ vent_matrix_server_name }}

# Vent session token signing + at-rest encryption of server-held Dendrite credentials.
JWT_SECRET={{ vault_vent_jwt_secret }}
CRED_ENC_KEY={{ vault_vent_cred_enc_key }}

# Keycloak OIDC relying-party config (Phase 1).
KEYCLOAK_ISSUER={{ keycloak_issuer }}
KEYCLOAK_CLIENT_ID={{ keycloak_client_id }}
VENT_WEB_CLIENT_SECRET={{ vault_vent_web_client_secret }}
OIDC_REDIRECT_URL=https://{{ vent_hostname }}/api/auth/callback
POST_LOGIN_URL=https://{{ vent_hostname }}/
CORS_ORIGIN=https://{{ vent_hostname }}

# LiveKit: API key/secret + signaling URL for clients; the server queries LiveKit on the host.
LIVEKIT_API_KEY={{ vault_livekit_api_key }}
LIVEKIT_API_SECRET={{ vault_livekit_api_secret }}
LIVEKIT_HOST={{ livekit_signal_url }}
LIVEKIT_URL=http://host.docker.internal:7880
