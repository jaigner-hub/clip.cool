# Patroni + Postgres {{ pg_ha_postgres_major }} (ADR 0016). Patroni is the entrypoint and
# starts/manages postgres itself — do NOT use the postgres image's default entrypoint.
FROM postgres:{{ pg_ha_postgres_major }}-bookworm

RUN apt-get update \
 && apt-get install -y --no-install-recommends python3 python3-pip curl \
 && rm -rf /var/lib/apt/lists/*

# PEP 668: the base image's Python is "externally managed"; --break-system-packages is fine in a
# single-purpose container. Pin Patroni; etcd3 extra = the v3 gRPC client.
RUN pip3 install --no-cache-dir --break-system-packages \
      'patroni[etcd3]==3.3.2' 'psycopg2-binary==2.9.9'

RUN mkdir -p /etc/patroni
COPY patroni-entrypoint.sh /usr/local/bin/patroni-entrypoint.sh
RUN chmod +x /usr/local/bin/patroni-entrypoint.sh

# Runs as root; the entrypoint chowns the data volume, then drops to 'postgres' via gosu.
ENTRYPOINT ["/usr/local/bin/patroni-entrypoint.sh"]
