-- Idempotent app role + database (ADR 0016). Rendered 0600, no_log; piped to `psql -f -` so the
-- \gexec meta-command works (it does NOT work inside `psql -c`). Each \gexec runs the DDL the SELECT
-- produces ONLY when the object is missing — safe to re-run on every deploy.
SELECT format('CREATE ROLE %I LOGIN PASSWORD %L', '{{ app_db_user }}', '{{ vault_app_db_password }}')
       WHERE NOT EXISTS (SELECT FROM pg_roles WHERE rolname = '{{ app_db_user }}')
\gexec

SELECT format('CREATE DATABASE %I OWNER %I', '{{ app_db_name }}', '{{ app_db_user }}')
       WHERE NOT EXISTS (SELECT FROM pg_database WHERE datname = '{{ app_db_name }}')
\gexec

-- Let the postgres_exporter (runs as the app user) read cluster/replication stats (idempotent).
GRANT pg_monitor TO {{ app_db_user }};

