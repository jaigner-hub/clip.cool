# Rendered 0600 by Ansible (no_log). Secrets are SOPS-sourced; Patroni reads PATRONI_* to override
# the non-secret patroni.yml (https://patroni.readthedocs.io/en/latest/ENVIRONMENT.html).

# Postgres superuser (Patroni manages it; also used by HAProxy health is REST-only, not this).
PATRONI_SUPERUSER_USERNAME=postgres
PATRONI_SUPERUSER_PASSWORD={{ vault_pg_superuser_password }}

# Streaming replication user.
PATRONI_REPLICATION_USERNAME={{ pg_ha_repl_user | default('replicator') }}
PATRONI_REPLICATION_PASSWORD={{ vault_pg_replication_password }}

# Patroni REST API auth (protects the unsafe restart/reinit/switchover endpoints).
PATRONI_RESTAPI_USERNAME={{ pg_ha_restapi_user | default('patroni') }}
PATRONI_RESTAPI_PASSWORD={{ vault_patroni_restapi_password }}

# App role password (created post-bootstrap by the role; also used in userlist.txt + by keygrip_web).
APP_DB_PASSWORD={{ vault_app_db_password }}

# Backblaze B2 (rclone) for the nightly pg_dump (ADR 0016).
B2_ACCOUNT_ID={{ vault_b2_account_id }}
B2_APP_KEY={{ vault_b2_app_key }}
