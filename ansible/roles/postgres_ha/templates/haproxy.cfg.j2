# HAProxy (ADR 0016) — routes the app's DB connections to the CURRENT Patroni leader, wherever it
# is. Patroni's REST API answers the health check: GET /primary => 200 ONLY on the leader, so the
# write backend has exactly one "up" server at a time. Failover = the new leader starts answering
# /primary 200, the old one stops; HAProxy re-points with no app change.
global
    maxconn 500
    log stdout format raw local0

defaults
    log     global
    mode    tcp
    retries 2
    timeout client  30m
    timeout server  30m
    timeout connect 5s
    timeout check   5s

# Stats UI (tailnet only — bound on host loopback by the container's host networking)
listen stats
    mode http
    bind 127.0.0.1:{{ pg_ha_haproxy_stats_port }}
    stats enable
    stats uri /
    stats refresh 5s

# --- WRITE / leader (session connections: the Procrastinate worker's LISTEN/NOTIFY lives here) ---
# Bound on 0.0.0.0 (host net) so app containers reach it via host.docker.internal:host-gateway.
# Restrict to the tailnet/loopback at the box firewall (ufw) — see the role README.
listen pgsql_write
    bind 0.0.0.0:{{ pg_ha_haproxy_write_port }}
    option httpchk GET /primary
    http-check expect status 200
    default-server inter 1s fall 2 rise 1 on-marked-down shutdown-sessions
{% for n in pg_ha_data_nodes %}
    server {{ n.name }} {{ n.address }}:5432 check port {{ patroni_rest_port }}
{% endfor %}

# --- READ-ONLY / replicas (optional; not used by the app yet) — GET /replica => 200 on replicas ---
listen pgsql_read
    bind 0.0.0.0:{{ pg_ha_haproxy_read_port }}
    option httpchk GET /replica
    http-check expect status 200
    balance roundrobin
    default-server inter 1s fall 2 rise 1 on-marked-down shutdown-sessions
{% for n in pg_ha_data_nodes %}
    server {{ n.name }} {{ n.address }}:5432 check port {{ patroni_rest_port }}
{% endfor %}
