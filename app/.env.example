# Copy to app/.env and fill in. app/.env is gitignored.
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: run the Procrastinate queue locally against a Postgres container (ADR 0008).
# Leave unset for default SQLite dev (the queue is simply absent). See compose.dev.yml.
# DEV_DB=postgres
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=keygrip
# DB_USER=keygrip
# DB_PASSWORD=keygrip

# Keycloak keygrip realm
KEYCLOAK_ISSUER=https://id.vent.dog/realms/keygrip
OIDC_RP_CLIENT_ID=keygrip-web
# Get the secret with:  ../bin/secrets get dev vault_keygrip_web_client_secret
OIDC_RP_CLIENT_SECRET=

# Recommendations API → OpenRouter (Claude models; ADR 0013). SOPS-managed in prod (see the
# secret inventory in docs/adr/0001-secrets-management.md). Unset ⇒ generation raises a clear
# error; the rest of the app still runs.
OPENROUTER_API_KEY=
# OPENROUTER_REFERER=https://app.vent.dog
# OPENROUTER_TITLE=Keygrip Recommendations
