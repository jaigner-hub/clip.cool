#!/usr/bin/env bash
# secrets — safe wrapper around SOPS (age) for our encrypted Ansible group_vars.
#
# Why this exists: ad-hoc `sops` is a footgun here — it errors on "no matching
# creation rules" whenever a path doesn't match .sops.yaml, and a failed
# `sops … > file` truncates the real file. This tool removes those traps:
# every mutation is  backup → operate on a temp → validate (decrypt round-trip)
# → atomic mv,  and reads/writes use the incantations proven to work.
#
# Layout:  ansible/group_vars/<env>/secrets.sops.yml   (env: dev|staging|prod)
# Needs:   sops, python3+pyyaml, and an age key
#          (SOPS_AGE_KEY_FILE, default ~/.config/sops/age/keys.txt)
#
# Usage:
#   bin/secrets view    <env>                # print decrypted contents
#   bin/secrets keys     <env>               # list key names (no values)
#   bin/secrets get      <env> <KEY>         # print one value
#   bin/secrets set      <env> <KEY> <VALUE> # add/update one value
#   bin/secrets unset    <env> <KEY>         # remove one value
#   bin/secrets edit     <env>               # $EDITOR on a decrypted temp, re-encrypt
#   bin/secrets validate [env]               # decrypt round-trip check (all envs if omitted)
#   bin/secrets backups  <env>               # list local backups
#   bin/secrets restore  <env> [N]           # restore Nth most-recent backup (1=newest)
#   bin/secrets rotate   <env>               # re-encrypt to current .sops.yaml recipients
#   bin/secrets hook-install                 # git pre-commit guard (blocks plaintext)
set -euo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; BLUE=$'\033[0;34m'; NC=$'\033[0m'
err(){  printf '%b\n' "${RED}[error]${NC} $*" >&2; }
ok(){   printf '%b\n' "${GREEN}[ok]${NC} $*"; }
info(){ printf '%b\n' "${BLUE}[info]${NC} $*"; }
warn(){ printf '%b\n' "${YELLOW}[warn]${NC} $*"; }

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$HOME/.local/bin:$PATH"
export SOPS_AGE_KEY_FILE="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
BACKUP_DIR="$REPO_ROOT/.secrets-backups"
MAX_BACKUPS=10
VALID_ENVS=(dev staging prod)
export HEADER="# SOPS-encrypted (age). Manage via bin/secrets — do not hand-edit."

command -v sops    >/dev/null || { err "missing dependency: sops"; exit 1; }
command -v python3 >/dev/null || { err "missing dependency: python3"; exit 1; }

enc_for(){ echo "$REPO_ROOT/ansible/group_vars/$1/secrets.sops.yml"; }

check_env(){
  local e="${1:-}" v
  [ -n "$e" ] || { err "env required (one of: ${VALID_ENVS[*]})"; exit 1; }
  for v in "${VALID_ENVS[@]}"; do [ "$e" = "$v" ] && return 0; done
  err "invalid env '$e' (valid: ${VALID_ENVS[*]})"; exit 1
}

require_file(){ [ -f "$1" ] || { err "no secrets file: $1"; exit 1; }; }

recipients_of(){ grep 'recipient:' "$1" | awk '{print $3}' | paste -sd, -; }

decrypt_stdout(){ sops -d --config /dev/null "$1"; }

validate_file(){
  local f="$1"
  [ -f "$f" ] || { err "not found: $f"; return 1; }
  [ -s "$f" ] || { err "empty: $f"; return 1; }
  grep -q 'ENC\[' "$f" || { err "no encrypted data: $f"; return 1; }
  grep -q '^sops:' "$f" || { err "no sops metadata: $f"; return 1; }
  sops -d --config /dev/null "$f" >/dev/null 2>&1 || { err "does not decrypt: $f"; return 1; }
  return 0
}

backup_file(){
  local env="$1" f; f="$(enc_for "$env")"
  [ -f "$f" ] || return 0
  mkdir -p "$BACKUP_DIR"
  cp "$f" "$BACKUP_DIR/$env.$(date +%Y%m%d_%H%M%S).sops.yml"
  ls -1t "$BACKUP_DIR/$env."*.sops.yml 2>/dev/null | tail -n +$((MAX_BACKUPS + 1)) | xargs -r rm -f
}

# Re-encrypt a decrypted temp -> atomically replace the env file (backup + validate first).
seal(){ # seal <env> <plaintext_temp>
  local env="$1" plain="$2" f; f="$(enc_for "$env")"
  local recips; recips="$(recipients_of "$f")"
  [ -n "$recips" ] || { err "no recipients in $f"; return 1; }
  local tmp; tmp="$(mktemp --suffix=.yml)"
  if ! sops -e --config /dev/null --age "$recips" --input-type yaml --output-type yaml "$plain" > "$tmp" 2>/dev/null; then
    rm -f "$tmp"; err "encryption failed"; return 1
  fi
  # sops infers format from extension; temps are .yml, but stay explicit (--input-type) regardless.
  if ! { [ -s "$tmp" ] && grep -q 'ENC\[' "$tmp" && sops -d --config /dev/null --input-type yaml "$tmp" >/dev/null 2>&1; }; then
    rm -f "$tmp"; err "encryption produced an invalid file (original untouched)"; return 1
  fi
  backup_file "$env"
  mv "$tmp" "$f"
}

cmd_view(){ check_env "${1:-}"; require_file "$(enc_for "$1")"; decrypt_stdout "$(enc_for "$1")"; }

cmd_keys(){
  check_env "${1:-}"; require_file "$(enc_for "$1")"
  decrypt_stdout "$(enc_for "$1")" | python3 -c 'import sys,yaml; d=yaml.safe_load(sys.stdin) or {}; print("\n".join(d.keys()))'
}

cmd_get(){
  check_env "${1:-}"; local key="${2:-}"
  [ -n "$key" ] || { err "key required"; exit 1; }
  require_file "$(enc_for "$1")"
  sops -d --config /dev/null --extract "[\"$key\"]" "$(enc_for "$1")"
}

_rewrite(){ # _rewrite <env> <python-mutation>   (mutation operates on dict `d`)
  local env="$1" mut="$2" f; f="$(enc_for "$env")"; require_file "$f"
  local plain; plain="$(mktemp)"
  if ! MUT="$mut" python3 - "$f" > "$plain" <<'PY'
import sys, os, subprocess, yaml
f = sys.argv[1]
raw = subprocess.run(["sops","-d","--config","/dev/null",f], capture_output=True, text=True, check=True).stdout
d = yaml.safe_load(raw) or {}
exec(os.environ["MUT"])
print(os.environ["HEADER"])
yaml.safe_dump(d, sys.stdout, default_flow_style=False, sort_keys=True)
PY
  then rm -f "$plain"; err "could not rewrite $env"; exit 1; fi
  if seal "$env" "$plain"; then shred -u "$plain" 2>/dev/null || rm -f "$plain"
  else shred -u "$plain" 2>/dev/null || rm -f "$plain"; exit 1; fi
}

cmd_set(){
  check_env "${1:-}"; local key="${2:-}" val="${3:-}"
  [ -n "$key" ] || { err "key required"; exit 1; }
  [ -n "$val" ] || { err "value required"; exit 1; }
  export K="$key" V="$val"
  _rewrite "$1" 'd[os.environ["K"]] = os.environ["V"]'
  ok "set $key in $1"
}

cmd_unset(){
  check_env "${1:-}"; local key="${2:-}"
  [ -n "$key" ] || { err "key required"; exit 1; }
  export K="$key"
  _rewrite "$1" 'd.pop(os.environ["K"], None)'
  ok "removed $key from $1"
}

cmd_edit(){
  check_env "${1:-}"; local f; f="$(enc_for "$1")"; require_file "$f"
  local plain; plain="$(mktemp)"
  decrypt_stdout "$f" > "$plain" || { rm -f "$plain"; err "decrypt failed"; exit 1; }
  "${EDITOR:-vi}" "$plain"
  if seal "$1" "$plain"; then ok "updated $1"; else warn "left unchanged (backup kept)"; fi
  shred -u "$plain" 2>/dev/null || rm -f "$plain"
}

cmd_validate(){
  local env="${1:-}" rc=0
  if [ -n "$env" ]; then check_env "$env"; validate_file "$(enc_for "$env")" && ok "$env valid" || rc=1
  else
    for env in "${VALID_ENVS[@]}"; do
      local f; f="$(enc_for "$env")"; [ -f "$f" ] || continue
      if validate_file "$f"; then ok "$env valid"; else rc=1; fi
    done
  fi
  return $rc
}

cmd_backups(){
  check_env "${1:-}"
  local list; mapfile -t list < <(ls -1t "$BACKUP_DIR/$1."*.sops.yml 2>/dev/null || true)
  [ "${#list[@]}" -gt 0 ] || { info "no backups for $1"; return 0; }
  local i=1; for b in "${list[@]}"; do echo "  $i) $(basename "$b")"; i=$((i + 1)); done
}

cmd_restore(){
  check_env "${1:-}"; local n="${2:-}"
  local list; mapfile -t list < <(ls -1t "$BACKUP_DIR/$1."*.sops.yml 2>/dev/null || true)
  [ "${#list[@]}" -gt 0 ] || { info "no backups for $1"; return 0; }
  if [ -z "$n" ]; then cmd_backups "$1"; echo "restore with: bin/secrets restore $1 <N>"; return 0; fi
  local b="${list[$((n - 1))]:-}"; [ -n "$b" ] || { err "invalid backup #$n"; exit 1; }
  backup_file "$1"; cp "$b" "$(enc_for "$1")"; ok "restored $(basename "$b")"
}

cmd_rotate(){
  check_env "${1:-}"; require_file "$(enc_for "$1")"
  backup_file "$1"
  ( cd "$REPO_ROOT" && sops updatekeys --yes "ansible/group_vars/$1/secrets.sops.yml" ) \
    && ok "rotated keys for $1 to match .sops.yaml" || { err "updatekeys failed"; exit 1; }
}

cmd_hook_install(){
  mkdir -p "$REPO_ROOT/.githooks"
  cat > "$REPO_ROOT/.githooks/pre-commit" <<'HOOK'
#!/usr/bin/env bash
# Refuse to commit a *.sops.yml that isn't SOPS-encrypted (catches accidental plaintext).
set -e
ROOT="$(git rev-parse --show-toplevel)"
fail=0
while IFS= read -r f; do
  [ -z "$f" ] && continue
  if ! grep -q 'ENC\[' "$ROOT/$f" 2>/dev/null; then
    echo "✗ $f is not SOPS-encrypted — refusing commit (use bin/secrets)"; fail=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM | grep -E 'secrets\.sops\.ya?ml$' || true)
exit $fail
HOOK
  chmod +x "$REPO_ROOT/.githooks/pre-commit"
  git -C "$REPO_ROOT" config core.hooksPath .githooks
  ok "installed .githooks/pre-commit and set core.hooksPath=.githooks"
}

usage(){ sed -n '2,40p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit 1; }

case "${1:-}" in
  view)        cmd_view "${2:-}" ;;
  keys)        cmd_keys "${2:-}" ;;
  get)         cmd_get "${2:-}" "${3:-}" ;;
  set)         cmd_set "${2:-}" "${3:-}" "${4:-}" ;;
  unset)       cmd_unset "${2:-}" "${3:-}" ;;
  edit)        cmd_edit "${2:-}" ;;
  validate)    cmd_validate "${2:-}" ;;
  backups)     cmd_backups "${2:-}" ;;
  restore)     cmd_restore "${2:-}" "${3:-}" ;;
  rotate)      cmd_rotate "${2:-}" ;;
  hook-install) cmd_hook_install ;;
  *)           usage ;;
esac
